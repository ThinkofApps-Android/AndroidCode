        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="Theme.SpeedMath.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_orange</item>
        <item name="postSplashScreenTheme">@style/Theme.SpeedMath</item>
    </style>
