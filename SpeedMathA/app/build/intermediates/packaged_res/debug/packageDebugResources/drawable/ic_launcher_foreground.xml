<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground layer.
    The 16dp inset keeps the stopwatch + equation pill inside the
    adaptive-icon safe zone (center ~66dp of the 108dp canvas), so
    nothing important gets cropped by circle / squircle / rounded-square
    launcher masks.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/ic_launcher_art"
    android:inset="16dp" />
