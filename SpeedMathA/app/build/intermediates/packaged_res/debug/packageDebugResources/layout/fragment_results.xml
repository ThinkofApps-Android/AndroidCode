<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:paddingHorizontal="20dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="@color/surface"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Grade + Score -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/tv_grade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏆 Perfect!"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:paddingBottom="6dp" />

                <TextView
                    android:id="@+id/tv_final_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="72sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent2"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="POINTS SCORED"
                    android:textSize="10sp"
                    android:textColor="@color/muted"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="20dp">

                <!-- Correct -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp"
                    android:background="@drawable/bg_stat_box"
                    android:layout_marginEnd="6dp">
                    <TextView android:id="@+id/tv_stat_correct"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="24sp" android:textStyle="bold"
                        android:textColor="@color/green" android:fontFamily="monospace"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CORRECT" android:textSize="8sp" android:textColor="@color/muted"
                        android:letterSpacing="0.1" android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- Wrong -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp"
                    android:background="@drawable/bg_stat_box"
                    android:layout_marginHorizontal="3dp">
                    <TextView android:id="@+id/tv_stat_wrong"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="24sp" android:textStyle="bold"
                        android:textColor="@color/red" android:fontFamily="monospace"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="WRONG" android:textSize="8sp" android:textColor="@color/muted"
                        android:letterSpacing="0.1" android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- Accuracy -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp"
                    android:background="@drawable/bg_stat_box"
                    android:layout_marginStart="6dp">
                    <TextView android:id="@+id/tv_stat_accuracy"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="24sp" android:textStyle="bold"
                        android:textColor="@color/accent2" android:fontFamily="monospace"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ACCURACY" android:textSize="8sp" android:textColor="@color/muted"
                        android:letterSpacing="0.1" android:fontFamily="monospace"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Accuracy Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="ACCURACY"
                        android:textSize="9sp" android:textColor="@color/muted"
                        android:letterSpacing="0.12" android:fontFamily="monospace"/>
                    <TextView android:id="@+id/tv_accuracy_label"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="" android:textSize="11sp" android:textColor="@color/accent2"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/accuracy_bar_container"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_bar_track">

                    <View
                        android:id="@+id/accuracy_bar_fill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_bar_fill" />
                </FrameLayout>
            </LinearLayout>

            <!-- Play Again -->
            <Button
                android:id="@+id/btn_play_again"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="↺  PLAY AGAIN"
                android:textColor="@color/accent2"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:background="@drawable/bg_btn_play_again" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
